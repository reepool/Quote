{
  "scheduler_config": {
    "enabled": true,
    "timezone": "Asia/Shanghai",
    "max_instances": 10,
    "misfire_grace_time": 300,
    "coalesce": true,
    "monitor_startup_delay": 3,
    "market_close_delay_minutes": 15,
    "jobs": {
      "daily_data_update": {
        "enabled": true,
        "description": "每日数据更新任务（沪深A股）",
        "report": true,
        "pre_run_notify": true,
        "trigger": {
          "type": "cron",
          "day_of_week": "mon-fri",
          "hour": 20,
          "minute": 0,
          "second": 0
        },
        "max_instances": 1,
        "misfire_grace_time": 600,
        "coalesce": true,
        "parameters": {
          "exchanges": [
            "SSE",
            "SZSE",
            "BSE"
          ],
          "wait_for_market_close": true,
          "market_close_delay_minutes": 15,
          "enable_trading_day_check": true,
          "max_runtime_seconds": 21600,
          "per_instrument_timeout_sec": 420,
          "progress_log_every": 200,
          "progress_log_interval_sec": 300
        }
      },
      "hk_daily_data_update": {
        "enabled": true,
        "description": "港股每日数据更新（16:00 HKT 收盘后）",
        "report": true,
        "pre_run_notify": true,
        "trigger": {
          "type": "cron",
          "day_of_week": "mon-fri",
          "hour": 17,
          "minute": 30,
          "second": 0
        },
        "max_instances": 1,
        "misfire_grace_time": 600,
        "coalesce": true,
        "parameters": {
          "exchanges": [
            "HKEX"
          ],
          "wait_for_market_close": false,
          "enable_trading_day_check": true,
          "max_runtime_seconds": 7200,
          "per_instrument_timeout_sec": 420,
          "progress_log_every": 200,
          "progress_log_interval_sec": 300
        }
      },
      "us_daily_data_update": {
        "enabled": false,
        "description": "美股每日数据更新（16:00 ET 收盘，次日 06:00 CST 更新）",
        "report": true,
        "pre_run_notify": true,
        "trigger": {
          "type": "cron",
          "day_of_week": "tue-sat",
          "hour": 6,
          "minute": 0,
          "second": 0
        },
        "max_instances": 1,
        "misfire_grace_time": 600,
        "coalesce": true,
        "parameters": {
          "exchanges": [
            "NASDAQ",
            "NYSE"
          ],
          "wait_for_market_close": false,
          "enable_trading_day_check": true,
          "max_runtime_seconds": 10800,
          "per_instrument_timeout_sec": 420,
          "progress_log_every": 500,
          "progress_log_interval_sec": 300
        }
      },
      "system_health_check": {
        "enabled": true,
        "description": "系统健康检查",
        "report": true,
        "pre_run_notify": false,
        "trigger": {
          "type": "interval",
          "hours": 1,
          "minutes": 0,
          "seconds": 0
        },
        "max_instances": 1,
        "misfire_grace_time": 300,
        "coalesce": true,
        "parameters": {
          "check_data_sources": true,
          "check_database": true,
          "check_disk_space": true,
          "check_memory_usage": true,
          "check_telegram": true,
          "disk_space_threshold_mb": 1000,
          "memory_threshold_percent": 85,
          "health_check_timeout_sec": 30,
          "max_runtime_seconds": 120
        }
      },
      "market_dependency_version_check": {
        "enabled": true,
        "description": "行情数据依赖版本检查",
        "report": false,
        "pre_run_notify": false,
        "trigger": {
          "type": "cron",
