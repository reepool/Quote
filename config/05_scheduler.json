      "daily_data_update": {
        "enabled": true,
        "description": "每日数据更新任务（沪深A股）",
        "report": true,
        "pre_run_notify": true,
        "trigger": {
          "type": "cron",
          "day_of_week": "mon-fri",
          "hour": 20,
          "minute": 0,
          "second": 0
        },
        "max_instances": 1,
        "misfire_grace_time": 600,
        "coalesce": true,
        "parameters": {
          "exchanges": [
            "SSE",
            "SZSE",
            "BSE"
          ],
          "wait_for_market_close": true,
          "market_close_delay_minutes": 15,
          "enable_trading_day_check": true,
          "max_runtime_seconds": 21600,
          "per_instrument_timeout_sec": 420,
          "progress_log_every": 200,
          "progress_log_interval_sec": 300,
          "instrument_types": [
            "stock",
            "index"
          ]
        }
      },
      "hk_daily_data_update": {
        "enabled": true,
        "description": "港股每日数据更新（16:00 HKT 收盘后，前置 HKEX 主数据 lifecycle_write 治理）",
        "report": true,
        "pre_run_notify": true,
        "trigger": {
          "type": "cron",
          "day_of_week": "mon-fri",
          "hour": 17,
          "minute": 30,
          "second": 0
        },
        "max_instances": 1,
        "misfire_grace_time": 600,
        "coalesce": true,
        "parameters": {
          "exchanges": [
            "HKEX"
          ],
          "wait_for_market_close": false,
          "enable_trading_day_check": true,
          "max_runtime_seconds": 7200,
          "per_instrument_timeout_sec": 420,
          "progress_log_every": 200,
          "progress_log_interval_sec": 300
        }
      },
      "hkex_instrument_master_sync": {
        "enabled": true,
        "manual_only": true,
        "description": "港股主数据同步（仅手工触发，lifecycle_write 写入官方生命周期变更）",
        "report": true,
        "pre_run_notify": false,
        "max_instances": 1,
        "misfire_grace_time": 600,
        "coalesce": true,
        "parameters": {
          "mode": "lifecycle_write",
          "timeout_sec": 60,
          "max_runtime_seconds": 600
