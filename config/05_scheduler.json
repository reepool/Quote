        "max_instances": 1,
        "misfire_grace_time": 600,
        "coalesce": true,
        "parameters": {
          "packages": [
            {
              "name": "pytdx",
              "distribution": "pytdx"
            },
            {
              "name": "baostock",
              "distribution": "baostock"
            },
            {
              "name": "akshare",
              "distribution": "akshare"
            },
            {
              "name": "akshare_proxy_patch",
              "distribution": "akshare-proxy-patch"
            },
            {
              "name": "yfinance",
              "distribution": "yfinance"
            },
            {
              "name": "curl_cffi",
              "distribution": "curl_cffi"
            }
          ],
          "timeout_sec": 10.0,
          "notify_when_latest": false,
          "max_runtime_seconds": 120
        }
